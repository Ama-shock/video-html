{
    "compilerOptions": {
        "strict": true,
        "jsx": "react-jsx",
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ESNext",
            "WebWorker"
        ],
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "cf-worker"]
}
