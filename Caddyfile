:80 {
    root * /srv/public

    # ゲートウェイ API エンドポイントを wrangler dev にリバースプロキシ
    handle /vapid-public-key {
        reverse_proxy gateway:3000
    }
    handle /gateway-key-id {
        reverse_proxy gateway:3000
    }
    handle /push {
        reverse_proxy gateway:3000
    }

    # 静的ファイルを提供（存在しないパスは SPA の index.html へフォールバック）
    try_files {path} /index.html
    file_server
}
